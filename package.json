{
  "name": "birrforex-challenges-bot",
  "version": "1.0.1",
  "description": "BirrForex Weekly Challenge Bot - Automated quiz challenges with prizes",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc && cp src/database/*.sql dist/database/",
    "start": "node dist/database/migrate.js && node dist/index.js",
    "migrate": "ts-node src/database/migrate.ts",
    "migrate:prod": "node dist/database/migrate.js"
  },
  "keywords": [
    "telegram",
    "bot",
    "quiz",
    "challenge"
  ],
  "author": "BirrForex",
  "license": "MIT",
  "dependencies": {
    "@types/node": "^20.10.6",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.10.9",
    "axios": "^1.13.6",
    "date-fns": "^2.30.0",
    "date-fns-tz": "^2.0.0",
    "dotenv": "^16.3.1",
    "node-cron": "^3.0.3",
    "pg": "^8.11.3",
    "telegraf": "^4.15.0",
    "typescript": "^5.3.3"
  },
  "devDependencies": {
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0"
  }
}
